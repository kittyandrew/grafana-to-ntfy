# Target ntfy.sh topic URL. Server starts without it but reports unhealthy (503)
# and rejects all alerts until set.
NTFY_URL=

# Basic auth credentials for your ntfy.sh instance/topic.
# Required if your ntfy topic is access-controlled. Omit both for public topics.
# Setting only one will send auth to ntfy with an empty value for the missing credential.
NTFY_BAUTH_USER=
NTFY_BAUTH_PASS=

# Credentials for Grafana/Alertmanager to authenticate into this service.
# Omit both to allow unauthenticated access. Setting only one will enforce auth
# with an empty value for the missing credential — always set both or neither.
BAUTH_USER=
BAUTH_PASS=

# Enable markdown formatting in notifications (optional).
# Any non-empty value is passed as-is in the X-Markdown header to ntfy.
# See: https://docs.ntfy.sh/publish/#markdown-formatting
MARKDOWN=
